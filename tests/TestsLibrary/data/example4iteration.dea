proc printHeader(string title) {
    print("\n----- ", title, " -----\n");
    return;
}

proc greet(string name) {
    print("Hello, ", name, "\n");
    return;
}

func int sum(int a, int b) {
    return a + b;
}

func int max2(int a, int b) {
    if (a > b) {
        return a;
    } else {
        return b;
    }
}

func int getLen(string s) {
    return len(s);
}

func bool alwaysTrue() {
    print("alwaysTrue called\n");
    return true;
}

func bool alwaysFalse() {
    print("alwaysFalse called\n");
    return false;
}

func int main() {
    printHeader("BOOL");
    bool ok = true;
    bool fail = false;

    if (ok) {
        print("ok = true\n");
    } else {
        print("ok = false\n");
    }

    if (fail) {
        print("fail = true\n");
    } else {
        print("fail = false\n");
    }

    printHeader("COMPARE");
    bool c1 = 2 < 3;
    bool c2 = 5 <= 5;
    bool c3 = 10 > 1;
    bool c4 = 10 >= 10;
    bool c5 = 7 == 7;
    bool c6 = 7 != 8;

    print(c1, "\n");
    print(c2, "\n");
    print(c3, "\n");
    print(c4, "\n");
    print(c5, "\n");
    print(c6, "\n");

    printHeader("LOGIC");
    bool l1 = true && true;
    bool l2 = true && false;
    bool l3 = false || true;
    bool l4 = !(2 > 5);

    print(l1, "\n");
    print(l2, "\n");
    print(l3, "\n");
    print(l4, "\n");

    printHeader("FUNCTIONS");
    int s = sum(7, 5);
    int m = max2(10, 3);

    print("sum(7, 5) = ", s, "\n");
    print("max2(10, 3) = ", m, "\n");

    printHeader("PROCEDURE");
    greet("Danil");

    printHeader("BUILTIN");
    string name = "Danil";
    int n = getLen(name);
    print("len(name) = ", n, "\n");

    printHeader("IF WITH FUNCTION");
    if (max2(20, 9) == 20) {
        print("if with function works\n");
    } else {
        print("if with function failed\n");
    }

    printHeader("SHORT CIRCUIT OR");
    bool sc1 = alwaysTrue() || alwaysFalse();
    print("result = ", sc1, "\n");

    printHeader("SHORT CIRCUIT AND");
    bool sc2 = alwaysFalse() && alwaysTrue();
    print("result = ", sc2, "\n");

    printHeader("IMPLICIT TO BOOL");
    if (1) {
        print("int -> bool works\n");
    } else {
        print("int -> bool failed\n");
    }

    if ("abc") {
        print("string -> bool works\n");
    } else {
        print("string -> bool failed\n");
    }

    printHeader("FINAL");
    print("All checks finished\n");

    return 0;
}